{
  "name": "ignition-poker-tracker",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "harness:build": "node side-panel/harness/build-harness.mjs",
    "harness": "node side-panel/harness/build-harness.mjs && npx serve side-panel/harness/dist -l 3333",
    "harness:verify": "node side-panel/harness/build-harness.mjs && node side-panel/harness/verify-harness.mjs",
    "replay": "npx vitest run test/replay/",
    "replay:determinism": "node test/replay/replay-determinism.mjs",
    "replay:harness:build": "node side-panel/replay-harness/build.mjs",
    "replay:harness": "node side-panel/replay-harness/build.mjs && npx serve side-panel/replay-harness/dist -l 3333",
    "replay:screenshots": "node scripts/screenshot-corpus.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "vitest": "^3.1.0"
  }
}
