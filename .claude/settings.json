{
  "permissions": {
    "allow": [
      "Edit(**)",
      "Write(**)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(bash:*)",
      "Bash(git:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(./scripts/*:*)",
      "Bash(bash scripts/*:*)",
      "WebSearch",
      "WebFetch(domain:*)",
      "SlashCommand(**)",
      "Task(**)",
      "Glob(**)",
      "Grep(**)",
      "Read(**)"
    ],
    "ask": [
      "Bash(git push:*)",
      "ExitPlanMode"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/git-guard.cjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/secrets-scan.cjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/pre-commit-gate.cjs"
          }
        ]
      }
    ]
  }
}
