{
  "autoEscalationRules": {
    "decompositionDepthExceeded": {
      "threshold": 10,
      "escalationTarget": ["claude"],
      "priorityLevel": "critical"
    },
    "successRateBelow": {
      "threshold": 50.0,
      "escalationTarget": ["human", "claude"],
      "priorityLevel": "warning"
    },
    "timeoutExceeded": {
      "threshold": 1000,
      "escalationTarget": ["claude"],
      "priorityLevel": "auto"
    }
  },
  "thresholds": {
    "maxDecompositionAttempts": 5,
    "minSuccessRatePct": 60.0,
    "maxTaskDurationMs": 2000
  }
}
