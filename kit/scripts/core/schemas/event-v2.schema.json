{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cwos.local/schemas/event-v2.json",
  "title": "cwos-event-v2",
  "description": "Shadow event log envelope — v2. ADDITIVE-ONLY over v1 (AS-34 contract). Same 13 required fields as v1; adds optional `trace_id` for distributed-trace correlation. v1 events MUST validate under this schema (backward-compat invariant).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schema_version",
    "timestamp",
    "author",
    "source_tier",
    "source_track",
    "track_tag",
    "command_id",
    "content_hash",
    "prior_hash",
    "payload"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "schema_version": { "type": "integer", "minimum": 1, "maximum": 2 },
    "timestamp": { "type": "string", "format": "date-time" },
    "author": { "type": "string", "minLength": 1, "maxLength": 128 },
    "source_tier": {
      "type": "string",
      "enum": ["founder-prompt", "llm-emission", "reducer-output", "external-paste"]
    },
    "source_track": { "type": "string", "minLength": 1, "maxLength": 64 },
    "track_tag": { "type": "string", "maxLength": 128 },
    "command_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "content_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "prior_hash": { "oneOf": [{ "type": "string", "pattern": "^[0-9a-f]{64}$" }, { "type": "string", "const": "" }] },
    "payload": {
      "oneOf": [
        { "type": "object" },
        {
          "type": "object",
          "required": ["payload_ref", "payload_hash"],
          "properties": {
            "payload_ref": { "type": "string" },
            "payload_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
          }
        }
      ]
    },
    "causation_id": { "type": ["string", "null"], "maxLength": 128 },
    "classifier_version": { "type": "string", "maxLength": 64 },
    "trace_id": {
      "description": "Optional distributed-trace correlation ID. Added in v2. v1 events omit this field (additive-only contract).",
      "type": ["string", "null"],
      "maxLength": 128
    }
  }
}
