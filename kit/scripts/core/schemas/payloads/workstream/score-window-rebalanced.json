{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cwos.local/schemas/payloads/workstream/score-window-rebalanced.json",
  "title": "workstream.score-window-rebalanced",
  "description": "T6:workstream-rebalance commit event (WS-264, ADR-037 RISK-2 / AS-037-10). Single atomic boundary for multi-file invalidation fan-out. Emitted after staging + before promotion of WS-*.yaml updates so the event log records which IDs were rewritten and what content hash they should land at; recovery uses content_hashes to verify post-promotion integrity.",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "rebalance_id", "trigger_reason", "touched_ws_ids", "content_hashes"],
  "properties": {
    "type": { "type": "string", "const": "score_window_rebalanced" },
    "rebalance_id": { "type": "string", "minLength": 1, "maxLength": 64 },
    "trigger_reason": {
      "type": "string",
      "enum": ["sprint-completed", "engine-run-completed", "context-updated", "manual", "recovered"]
    },
    "trigger_event_id": { "type": ["string", "null"] },
    "touched_ws_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^WS-[0-9]+$" }
    },
    "content_hashes": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
    }
  }
}
