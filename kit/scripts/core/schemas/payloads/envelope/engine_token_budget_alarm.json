{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cwos.local/schemas/payloads/envelope/engine_token_budget_alarm.json",
  "title": "envelope.engine_token_budget_alarm",
  "description": "T0:envelope engine_token_budget_alarm event payload (WS-289). Emitted when cwos-token-budget detects a per-engine regression (3 consecutive monotonic increases on tokens_derived for one engine_id AND latest > earliest * (1 + threshold_pct=0.20)). Distinct from budget_regression_blocked so downstream consumers can route per-engine alarms separately from /next-tag alarms.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type", "tag", "engine_id", "tokens_t0", "tokens_t1", "tokens_t2",
    "pct_increase", "threshold_pct", "command_ids", "reason",
    "composed_by", "detected_at"
  ],
  "properties": {
    "type":          { "type": "string", "const": "engine_token_budget_alarm" },
    "tag":           { "type": "string", "pattern": "^/engine/[A-Za-z0-9._:-]+$" },
    "engine_id":     { "type": "string", "minLength": 1 },
    "tokens_t0":     { "type": "integer", "minimum": 0 },
    "tokens_t1":     { "type": "integer", "minimum": 0 },
    "tokens_t2":     { "type": "integer", "minimum": 0 },
    "pct_increase":  { "type": "number" },
    "threshold_pct": { "type": "number" },
    "command_ids":   { "type": "array", "items": { "type": "string" }, "minItems": 3 },
    "run_ids":       { "type": "array", "items": { "type": ["string", "null"] } },
    "reason":        { "type": "string", "minLength": 1 },
    "composed_by":   { "type": "string", "const": "cli-deterministic" },
    "detected_at":   { "type": "string", "format": "date-time" }
  }
}
